# Wedge (triangular prism)
v -0.500 -0.500 -0.500
v 0.500 -0.500 -0.500
v -0.500 -0.500 0.500
v 0.500 -0.500 0.500
v -0.500 0.500 -0.500
v 0.500 0.500 -0.500

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Bottom face
f 1/1 2/2 4/3
f 1/1 4/3 3/4

# Back face
f 1/1 5/4 6/3
f 1/1 6/3 2/2

# Slope face
f 3/1 4/2 6/3
f 3/1 6/3 5/4

# Left triangle
f 1/1 3/2 5/3

# Right triangle
f 2/1 6/3 4/2
